# Supabase Configuration
# Replace these with your actual Supabase project details
# You can find these in your Supabase Dashboard -> Project Settings -> API
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# RevenueCat — Subscriptions/IAP (optional, leave empty for demo mode)
# https://app.revenuecat.com → Project Settings → API Keys (public SDK keys)
EXPO_PUBLIC_REVENUECAT_KEY_IOS=
EXPO_PUBLIC_REVENUECAT_KEY_ANDROID=

# Sentry — Error monitoring (optional, leave empty to disable)
# https://sentry.io → New Project → React Native → DSN
EXPO_PUBLIC_SENTRY_DSN=

# PostHog — Product analytics (optional, leave empty to disable)
# https://eu.posthog.com → New Project → API Key
EXPO_PUBLIC_POSTHOG_KEY=

# AdMob ad unit IDs (production only — __DEV__ builds always use Google test IDs)
# https://apps.admob.com → Apps → Ad units. If left empty in production,
# that ad format is silently disabled (with a console warning).
EXPO_PUBLIC_ADMOB_BANNER_ANDROID=
EXPO_PUBLIC_ADMOB_BANNER_IOS=
EXPO_PUBLIC_ADMOB_INTERSTITIAL_ANDROID=
EXPO_PUBLIC_ADMOB_INTERSTITIAL_IOS=
EXPO_PUBLIC_ADMOB_REWARDED_ANDROID=
EXPO_PUBLIC_ADMOB_REWARDED_IOS=
