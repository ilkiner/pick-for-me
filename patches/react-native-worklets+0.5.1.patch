+    return cloneNumber(value) as SerializableRef<TValue>;
+  }
+
+  if (typeof value === 'boolean') {
+    return cloneBoolean(value) as SerializableRef<TValue>;
+  }
+
+  if (typeof value === 'bigint') {
+    return cloneBigInt(value) as SerializableRef<TValue>;
+  }
